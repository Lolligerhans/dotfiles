declare -agi _timer_stack=() # Push $SECONDS incrementally using a DEBUG trap
declare -agi _timer_diffs    # Pairwise difference of _timer_stack
declare -gi _timer_total
declare -g _timer_report # Relevant entries of _timer_diffs

_timer_start() {
  _timer_stack+=("$SECONDS")
}

trap '_timer_start' DEBUG

_timer_stop() {
  declare -i command_count
  ((command_count = ${#PROMPT_COMMAND[@]}))
  if ((command_count < 1)); then 1>&2 printf -- "%s\n" "Warning: Expected non-empty PROMPT_COMMAND"; fi
  ((_timer_total = 0))
  _timer_diffs=()
  declare -i i _diff
  for ((i = command_count; i < ${#_timer_stack[@]}; ++i)); do
    ((diff = _timer_stack[i] - _timer_stack[i - 1]))
    ((_timer_total += diff))
    _timer_diffs+=("$diff")
  done
  _timer_stack=()
}

# declare -gr _prompt_current_date_and_time_minutes='\[${text_bdy}\]\D{%F} \[${text_bly}\]\A\[${text_normal}\]'
declare -gr _prompt_current_date_and_time_seconds='\[${text_bdy}\]\D{%F} \[${text_bly}\]\T\[${text_normal}\]'
declare -gr _prompt_virtual_env_indicator='$([[ -n "$VIRTUAL_ENV" ]] && printf " \[${text_purple}\]${_venv_dir}/\[${text_normal}${text_blp}\]${_venv_base}\[${text_normal}\]")'
declare -gr _prompt_user_and_host='\[${text_dim}\] \u ⌂ \H\[${text_normal}\]'
declare -gr _prompt_pwd='\[${text_italic}${text_blue}\]${_pwd_dir}/\[${text_blb}\]${_pwd_name}\[${text_normal}\]'
declare -rg _prompt_dirs='$(((_dirs_count!=0))&&printf " %s" "\[${text_bb}\]<\[${text_blb}\]$((_dirs_count+1))\[${text_bb}\]>\[${text_normal}\]")'
declare -gr _prompt_jobs='$(((\j!=0))&&printf "\[${text_bc}\][\[${text_blc}\]\j\[${text_bc}\]]\[${text_normal}\] ")\[${text_normal}\]'
declare -gr _prompt_command_counters='\[${text_brightwhite}${text_dim}\]\! \[${text_normal}${text_brightblack}\]\#'
declare -gr _prompt_execution_report='$( (($_prompt_ret!=0)) && printf "\[${text_br}\]${_timer_report} (${_prompt_ret})" || printf "\[${text_bg}\]${_timer_report}")'

PROMPT_COMMAND='_prompt_command_wrapper'
# shellcheck disable=SC2016 # Expansion done when the prompt is used
_prompt_command_wrapper() {
  # Get return value first so it is the return value of the last user command
  declare -gi _prompt_ret="$?"

  _timer_stop
  printf -v _timer_report -- "%s" "${_timer_diffs[*]}"
  _timer_report+=" Σ $_timer_total"

  # Working dir
  declare -g _pwd_dir="${PWD/#"${HOME}"/"~"}" # == "~/example/dir"
  [[ "${_pwd_dir}" == "~" ]] && _pwd_dir="~/" # We match '/' so it must be there
  declare -g _pwd_name="${_pwd_dir##*/}"      # == "dir"
  _pwd_dir="${_pwd_dir%/*}"                   # == "~/example"
  #    1>&2 echo "DEBUG: _pwd=\"${_pwd}\" _pwd_dir=\"${_pwd_dir}\" _pwd_name=\"${_pwd_name}\"";

  # Add git repo
  declare -g _git_col=""
  declare -g _git_repo="$(git rev-parse --show-toplevel 2>/dev/null)"
  if [[ -n "$_git_repo" ]]; then
    if [[ "$_git_repo" == "$(pwd)" ]]; then
      _git_repo=""
    else
      _git_repo=" $(basename "$_git_repo")"
      # Light blue italic text
      _git_col="${text_ib}"
    fi
  fi

  # Add virtual env
  if [[ -n "$VIRTUAL_ENV" ]]; then
    declare -g _venv_dir="$(dirname "$VIRTUAL_ENV")" # TODO use bash internals
    declare -g _venv_base="$(basename "$VIRTUAL_ENV")"
  else
    :
    #declare -g _venv_base='';
    #declare -g _venv_dir='';
  fi

  # Add 'dirs' count
  declare -g _dirs_count="$(dirs -0 -v)" # == " 2 /home/example"
  _dirs_count="${_dirs_count/ [^0-9]*/}" # == "2"

  # Command counters and bash version
  #  \[${text_dim}\]\! \# \s\V\[${text_normal}\] (\l)

  # TODO Move this out of funciton. Is static anyway
  declare -r _new_before_git_ps1="${_prompt_pwd}${_prompt_dirs}"
  declare -r _new_after_git_ps1=' '"${_prompt_jobs}${_prompt_command_counters}"' '"${_prompt_execution_report}"' \$›\[${text_normal}\] '
  declare -r _new_git_ps1_format=' (\[${text_dim}${text_white}\]$(git config --get user.name)\[${text_normal}\]\[${_git_col}\]${_git_repo}\[${text_green}\]⎇\[${text_normal}\]  %s)'
  #    declare _ret="$?";
  # Termcap for bold text has a fallthrough in the __git_ps1 format string
  __git_ps1 "$_new_before_git_ps1" "$_new_after_git_ps1" "$_new_git_ps1_format"

} # _prompt_command_wrapper()

